# Server
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://<user>:<password>@<host0>:27017,<host1>:27017,<host2>:27017/voyageai?ssl=true&replicaSet=<replica-set-name>&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# AI APIs (required for document extraction and itinerary generation)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Client (Vite) — set in production when API is hosted separately
VITE_API_URL=

# Storage (optional — use cloudinary for production deploys without persistent disk)
STORAGE_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
