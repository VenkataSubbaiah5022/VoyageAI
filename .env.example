# Server
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://<user>:<password>@<host0>:27017,<host1>:27017,<host2>:27017/voyageai?ssl=true&replicaSet=<replica-set-name>&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# AI APIs (for future itinerary generation)
OPENAI_API_KEY=
GEMINI_API_KEY=
